{
  "Name": "Orthanc",
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": false,
  "Plugins": ["/usr/share/orthanc/plugins"],

  "MySQL": {
    "EnableIndex": true,
    "EnableStorage": false,
    "Host": "mysql",
    "Port": 3306,
    "Database": "orthanc",
    "Username": "orthanc",
    "Password": "orthanc"
  },

  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/",
    "EnableWado": true,
    "EnableQido": true,
    "EnableStow": true
  },
  "HttpHeaders": {
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
    "Access-Control-Allow-Headers": "*"
  }
}
